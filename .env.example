# Environment Variables for MasterNoder.dk
# Copy to .env and fill in API keys. Links below go directly to each provider's signup/API key page.
#
# Quick start: Copy this file to .env. Set at least one LLM key (e.g. OPENAI_API_KEY or GROQ_API_KEY).
# Get keys: Profile -> Agent Support -> Resources, or see docs/RESEARCH_AI_SYSTEMS.md section 8.

# ==================== Flask & App ====================
FLASK_ENV=production
FLASK_DEBUG=False
PRODUCTION=true
SECRET_KEY=your-secret-key-here-change-this-in-production
# Site root at domain (nginx serves /api, /vidgenerator, etc.); OAuth uses SOCIAL_AUTH_BASE_URL
APPLICATION_ROOT=/
BASE_URL=https://masternoder.dk
SOCIAL_AUTH_BASE_URL=https://masternoder.dk
# DB: systemd loads this file (see systemd/uwsgi-vidgenerator*.service EnvironmentFile=).
# SQLite relative path resolves under project root (/var/www/html) to an absolute file; ensure www-data can read/write instance/ and the .db file.
# On server after editing: chmod 640 /var/www/html/.env && chown root:www-data /var/www/html/.env
DATABASE_URL=sqlite:///instance/database.db
# Local-only (paramiko deploy scripts on your machine). Never commit real values.
# DEPLOY_HOST=masternoder.dk
# DEPLOY_USER=root
# DEPLOY_PASS=
OUTPUT_DIR=/var/www/html/vidgenerator/output
UPLOAD_DIR=/var/www/html/vidgenerator/uploads

# ==================== AI LLM providers (content + context) ====================
# Used for chat, embeddings, code, reasoning. See docs/RESEARCH_AI_SYSTEMS.md.
# Env names match backend.services.llm_service.PROVIDERS (api_key_env). Links: Profile → Agent Support → Resources.
#
# Prefer free-tier routing for task_type=default (Groq → Cerebras → Gemini → …, not OpenAI first).
# Set after you add GROQ_API_KEY and/or GOOGLE_AI_API_KEY (free keys).
# LLM_PREFER_FREE=1
#
# Agent AI Intelligence LLM insight endpoint: routing hint (default: free).
# AGENT_AI_LLM_TASK=free
#
# Optional: LLM request timeout in seconds (default 10).
# LLM_TIMEOUT_SECONDS=10

# OpenAI – primary LLM, embeddings (paid). AI context: chat, completions, embeddings.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_BEST=gpt-4o

# Groq – AI speed tier, 300+ tok/s (free tier). AI content: Llama 3.3 70B.
# https://console.groq.com/keys
GROQ_API_KEY=

# Google AI (Gemini) – long context 1M tokens, multimodal (free). AI context: Gemini 2.5 Flash/Pro.
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# OpenRouter – 30+ AI models, reasoning (free tier). AI content: Llama 4, DeepSeek R1.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cerebras – ultra-fast AI, 1M tok/day free. AI context: Llama 3.3 70B.
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# DeepSeek – AI reasoning, 5M free tokens. AI content: DeepSeek V3/R1.
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Mistral – AI code & general (free tier). AI content: Codestral, Large.
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# Together AI – OpenAI-compatible (Llama 3.3 70B, etc.).
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Anthropic – Claude (native API in llm_service).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Cohere – Command R+ (OpenAI-compatible endpoint).
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Fireworks AI – fast hosted Llama (OpenAI-compatible).
# https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# Hugging Face Inference router (OpenAI-compatible). Also reads HUGGINGFACE_HUB_TOKEN.
# https://huggingface.co/settings/tokens
HF_TOKEN=
# HF_INFERENCE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Ollama local — OpenAI-compatible at /v1. Enable only when a daemon is running.
# OLLAMA_ENABLED=0
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.3
# OLLAMA_API_KEY=

# Google Gemini – optional second key (same Studio); llm_service uses GOOGLE_GEMINI_API_KEY first, then GOOGLE_AI_API_KEY.
# https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=

# Azure OpenAI – set endpoint + deployment name + key.
# https://portal.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ==================== AI Video / Image providers ====================
# Used for AI-generated video clips and images in documentary flow.

# Runway ML – AI Gen-4 video clips.
# https://app.runwayml.com/settings/api
RUNWAYML_API_KEY=

# Pika Labs – AI Pika 2.2 video clips (or use fal.ai for Pika).
# https://pika.art/  or  https://fal.ai
PIKA_LABS_API_KEY=

# Stability AI – AI images and video. Content: Stable Diffusion, Stable Video.
# https://platform.stability.ai/account/keys
STABILITY_AI_API_KEY=
# Stable Video / Stable API (fallback env names in stability_image_service).
# https://platform.stability.ai/
STABLE_VIDEO_API_KEY=
STABLE_API_KEY=

# ModelsLab – AI CogVideoX, images.
# https://modelslab.com/dashboard/api-keys
MODELSLAB_API_KEY=

# Replicate – Stable Video Diffusion / image models (OpenAI-compatible token).
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# HeyGen – avatar / short video (optional pipeline).
# https://app.heygen.com/settings/api
HEYGEN_API_KEY=
# HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=

# Pollinations – free AI images, no key required.

# ==================== AI TTS (Text-to-Speech) ====================
# Used for video narration. Priority: Piper (local) → ElevenLabs → gTTS → pyttsx3.

# ElevenLabs – AI voice narration, 10K chars/month free.
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Piper – local AI TTS, no API key. Set path to dir containing .onnx voice models.
# https://github.com/rhasspy/piper
# PIPER_MODEL_PATH=

# AI audio enhancement (DeepFilterNet + FFmpeg loudnorm). 1 = on.
AUDIO_ENHANCE=1
AUDIO_ENHANCE_NOISE=1
AUDIO_ENHANCE_LOUDNORM=1

# ==================== Auth (not AI) ====================
# PayPal: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# Webhook verification for POST /api/monetization/webhooks/paypal-subscription (dashboard → Webhooks → Webhook id)
# PAYPAL_WEBHOOK_ID=
# Live Pro billing plan id (maps P-PLACEHOLDER-PRO template — no JSON rename):
# PAYPAL_SUBSCRIPTION_PLAN_PRO=P-5XXXXXXXX
# PAYPAL_SUBSCRIPTION_PLAN_MN_HOST=P-5XXXXXXXX
# Local/dev only: skip signature verification (never enable in production)
# PAYPAL_WEBHOOK_BYPASS=0

# ==================== MasterNoder2 (MN2) RPC ====================
# Required for MN2 deposit/withdraw/shop. Use config/masternoder2.conf for the daemon; set same rpcuser/rpcpassword here.
# See docs/MN2_DAEMON_SETUP.md and docs/MASTERNODER2_CRYPTO_INTEGRATION_EXPANDED.md Phase 1.
MN2_RPC_URL=http://127.0.0.1:9332
MN2_RPC_USER=mn2rpc
MN2_RPC_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# Optional hot-standby RPC (failover Top-10 #9). Set enabled:true in data/mn2_rpc_failover.json when ready.
# MN2_RPC_STANDBY_URL=http://127.0.0.1:9333
# MN2_RPC_STANDBY_USER=
# MN2_RPC_STANDBY_PASSWORD=
# Optional: testnet | mainnet. If MN2_RPC_URL is not set, mainnet uses 9332, testnet uses 19332.
# Set the daemon to the same network and port in masternoder2.conf (rpcport=9332 or 19332).
# MN2_NETWORK=mainnet
# Optional: set to 1 to log each RPC call to logs/mn2_rpc.jsonl (method, duration_ms, ok).
# MN2_PROFILE_LOG=0
# Optional: connection retry count when the daemon is down (default 2). Set 0 for no retries.
# MN2_RPC_MAX_RETRIES=2
# Optional: per-attempt RPC socket timeout in seconds (default and max 15).
# MN2_RPC_TIMEOUT=15
# Optional: POST /api/agent/shop/execute-mn2-purchase (automation / agents buying with MN2 balance) requires header X-Agent-Shop-Key.
# AGENT_MN2_SHOP_SECRET=

# Optional: if set, POST /api/mn2/scan-deposits requires X-Scanner-Token or ?token= to match (use in production).
# MN2_SCAN_SECRET=
# Optional: if set, GET /api/mn2/ops/stats requires X-Ops-Token or X-Scanner-Token or ?token= to match. Falls back to MN2_SCAN_SECRET if unset.
# MN2_OPS_SECRET=

# External casino/aggregator bet-win callbacks (POST /api/casino/callback/bet|win, /api/aggregators/callback/bet|win).
# Send header X-MN2-Callback-Token with this value. Required in production when callbacks.require_secret is true.
# MN2_CALLBACK_SECRET=
# Local/dev only: allow callbacks without secret (never enable in production)
# MN2_CALLBACK_BYPASS=1

# GitHub OAuth: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth: https://developers.facebook.com/apps/ → your app → Settings → Basic
# Add product "Facebook Login" → Valid OAuth Redirect URIs:
#   https://masternoder.dk/api/auth/facebook/callback
# App ID → FACEBOOK_CLIENT_ID, App Secret → FACEBOOK_CLIENT_SECRET (show secret in Basic settings)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Discord OAuth (login + link): https://discord.com/developers/applications
# Redirect: {SOCIAL_AUTH_BASE_URL}/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Legacy alias (optional)
# DISCORD_OAUTH_CLIENT_ID=
# DISCORD_OAUTH_CLIENT_SECRET=

# Store OAuth refresh tokens for provider revoke on unlink (recommended in production)
# SOCIAL_AUTH_STORE_TOKENS=1

# ==================== Feature flags / behavior ====================
# Shop: use shop-v3 API (true) or legacy game/shop (false). Set false when MN2/PayPal deps are off.
USE_SHOP_V3=true
# Gallery list cache TTL in seconds; reduces disk hits for /api/gallery/list.
GALLERY_CACHE_TTL_SEC=30

# ==================== COGS / unit economics (global USD defaults) ====================
# Reference job + per-completion metering: docs/REFERENCE_JOB_COGS.md
# GET /api/system/cogs/reference-job  |  GET /api/system/cogs/summary
# Defaults match backend.services.cogs_metering_service and monetization_tier_service.
COGS_RUNWAY_USD_PER_OUTPUT_SECOND=0.05
COGS_ENCODE_CPU_USD_PER_HOUR=0.02
COGS_GPU_USD_PER_HOUR=0.45
COGS_STORAGE_USD_PER_GB_MONTH=0.015
COGS_LLM_USD_PER_1K_TOKENS=0.0004
COGS_LLM_TOKENS_BASE=2500
COGS_LLM_TOKENS_PER_SEGMENT=800
COGS_ENCODE_ASSUME_GPU=0
# Optional: protect GET /api/system/cogs/metering-stats — send header X-Cogs-Admin-Key with this value
# COGS_ADMIN_REPORT_KEY=
# Tier C8 margin report: GET /api/monetization/report?since_days=7 (same key / X-Cogs-Admin-Key)

# ==================== LiveKit (D2 camgirls voice) ====================
# Create project at https://cloud.livekit.io — then set wss URL + API key/secret.
# GET /api/camgirls/livekit/status  |  POST /api/camgirls/livekit/token (after unlock)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# CAMGIRLS_VOICE_MN2_PER_MIN=0.5

# Optional: override base for logs (cogs metering, monetization ledger); default is project logs/
# MASTERNODER_LOG_DIR=

# ==================== Monetization (packs / tiers / ledger) ====================
# Override path to JSON (default: data/monetization_config.json)
# MONETIZATION_CONFIG_PATH=
# Tier caps before encode: 1=on, 0=off (default off so existing traffic unchanged)
# MONETIZATION_TIER_ENFORCEMENT=0
# Set to 1 on server to enforce Creator/Pro generator caps (402/403 over limit).
# Force tier for testing: creator | pro
# MONETIZATION_FORCE_TIER=
# Optional: protect POST /api/monetization/b2b/record-payment — header X-B2B-Ledger-Key or ?key=
# B2B_LEDGER_SECRET=
# SCR org pool (§4): reject video jobs when prepaid pool (ledger in − metering out) is below reserve
# MONETIZATION_ORG_POOL_ENFORCEMENT=0
# Minimum reservation per job in generation credits (omit = one reference job worth: 1 / reference_fraction_per_credit)
# MONETIZATION_ORG_POOL_MIN_CREDITS_PER_JOB=

# ==================== Storage / Server ====================
USE_EXTERNAL_STORAGE=false
STORAGE_TYPE=local
SFTP_ENABLED=false
SFTP_HOST=masternoder.dk
SFTP_USER=root
SFTP_PORT=22
SFTP_PATH=/var/www/videos
SFTP_PUBLIC_URL=https://masternoder.dk/videos

# ==================== Optional API keys (extra) ====================
# Hugging Face (inference): https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=
# HF_TOKEN=   # alias for llm_service huggingface provider (see AI LLM providers above)

# arXiv (intelligence aggregator) – no key required; optional key for higher rate limits.
# https://info.arxiv.org/help/api/
ARXIV_API_KEY=

# ==================== Casino agent LLM (autonomous betting) ====================
# Full setup guide: docs/CASINO_AGENT_AI_SETUP.md
# Routes: POST /api/agent/casino/run-all (header X-Agent-Casino-Key)
# Planner: backend/services/casino_agent_llm_planner.py → agent_ai_router (task_kind=casino_bet_plan)
#
# Required on server after deploy:
AGENT_CASINO_SECRET=
CASINO_AGENT_LLM=0
#
# At least one LLM key below when CASINO_AGENT_LLM=1 (reason chain: DeepSeek → OpenRouter → Anthropic → OpenAI → Groq)
# Free-tier picks: GROQ_API_KEY + GOOGLE_AI_API_KEY + DEEPSEEK_API_KEY (5M token signup grant)
# GROQ_API_KEY=          # https://console.groq.com/keys
# DEEPSEEK_API_KEY=      # https://platform.deepseek.com/api_keys
# GOOGLE_AI_API_KEY=     # https://aistudio.google.com/apikey
# OPENROUTER_API_KEY=    # https://openrouter.ai/keys (fallback / :free models)
#
# Optional (not wired in code yet — use CASINO_AGENT_LLM + LLM_TIMEOUT_SECONDS instead):
# CASINO_AGENT_AUTOMATION=1
# CASINO_AGENT_LLM_REQUIRED=0
# CASINO_AGENT_LLM_TIMEOUT=12

# ==================== Agent skills & reporter (cron) ====================
# KNOWLEDGE_REPORT_SECRET=   # Secured reporter cron; X-Reporter-Token or ?token=
# AGENT_CRON_SECRET=   # POST /api/agents/cron/run — daily/weekly/monthly bundles (see docs/RESEARCH_AI_SYSTEMS.md)
# AGENT_DAEMON_SECRET=   # scripts/agent_daemon.py → POST /api/agents/daemon/tick (can reuse AGENT_CRON_SECRET)
AGENT_DAEMON_CONTROLS_AUTOMATION=1
AGENT_DAEMON_INTERVAL_SEC=60
AGENT_DAEMON_URL=http://127.0.0.1:5000/api/agents/daemon/tick

# Gallery / AI quality gate (POST /api/gallery/quality-gate, /api/agents/evaluate/output)
GALLERY_QUALITY_MIN_SCORE=55
GALLERY_QUALITY_STRICT_MIN=65
GALLERY_QUALITY_EVAL_STRICT=0
# USER_SKILLS_MAINTENANCE_SECRET=   # POST /api/agents/user-skills/maintenance-inactive
USER_SKILLS_INACTIVE_DAYS=120

# ==================== Gallery admin (bulk LLM metadata) ====================
# If set, POST /api/gallery/enhance-metadata requires header X-Gallery-Admin-Token with this value.
# GALLERY_ADMIN_TOKEN=

# ==================== Notifications ====================
# NOTIFY_ADMIN_EMAIL=your@email.com
# NOTIFY_SMTP_HOST=
# NOTIFY_SMTP_USER=
# NOTIFY_SMTP_PASSWORD=

# ==================== Discord (M8 / Phase 5 news mirror) ====================
# Application ID = DISCORD_CLIENT_ID (Developer Portal → General Information)
# DISCORD_PUBLIC_KEY=   # same page — interactions endpoint verification
# Outbound webhook (default) or per-channel DISCORD_CHANNEL_ID_<NAME>
# DISCORD_WEBHOOK_URL=
# DISCORD_BOT_TOKEN=
# DISCORD_GUILD_ID=
# DISCORD_CHANNEL_ID_ANNOUNCEMENTS=
# DISCORD_CHANNEL_ID_CASINO=
# DISCORD_CHANNEL_ID_GENERATOR=
# DISCORD_CHANNEL_ID_GAME=
# DISCORD_CHANNEL_ID_MARKET=
# DISCORD_CHANNEL_ID_OPS=
# DISCORD_OPS_SECRET=   # cron + POST /api/discord/* ops routes
# Casino Discord fan-out (Gate S — off-request cron)
# CASINO_DISCORD_BLOCKED_COUNTRIES=US
# CASINO_BIG_WIN_THRESHOLD_COINS=1000
# CASINO_BIG_WIN_THRESHOLD_MN2=10
# CASINO_BIG_WIN_THRESHOLD_USD=50
# CASINO_DISCORD_VIP_MIN_MN2=100
# META_PIXEL_ID=          # optional Facebook/Meta Pixel — document only unless wired in UI
# ADMIN_OPS_SECRET=     # alias for customer aggregator admin
