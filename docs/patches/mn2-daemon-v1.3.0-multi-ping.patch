+bool CActiveMasternode::RegisterPingTarget(const std::string& alias, std::string& errorMessage)
+{
+    if (alias.empty()) {
+        errorMessage = "empty alias";
+        return false;
+    }
+
+    for (CMasternodeConfig::CMasternodeEntry mne : masternodeConfig.getEntries()) {
+        if (mne.getAlias() != alias)
+            continue;
+
+        int nIndex;
+        if (!mne.castOutputIndex(nIndex)) {
+            errorMessage = "invalid output index for alias " + alias;
+            return false;
+        }
+
+        CTxIn newVin = CTxIn(uint256(mne.getTxHash()), uint32_t(nIndex));
+        if (status == ACTIVE_MASTERNODE_STARTED && vin == newVin) {
+            errorMessage = "";
+            return true;
+        }
+
+        CMasternodePingTarget target;
+        target.alias = alias;
+        target.vin = newVin;
+        target.service = CService(mne.getIp());
+        target.strPrivKey = mne.getPrivKey();
+
+        CKey key;
+        CPubKey pubkey;
+        if (!obfuScationSigner.SetKey(mne.getPrivKey(), errorMessage, key, pubkey)) {
+            return false;
+        }
+        target.pubKeyMasternode = pubkey;
+        target.status = ACTIVE_MASTERNODE_INITIAL;
+
+        LOCK(cs_pingTargets);
+        mapExtraPingTargets[alias] = target;
+        LogPrintf("CActiveMasternode::RegisterPingTarget() - registered %s (%s)\n", alias, newVin.ToString());
+        errorMessage = "";
+        return true;
+    }
+
+    errorMessage = "could not find alias in masternode.conf: " + alias;
+    return false;
+}
+
+int CActiveMasternode::RegisterAllPingTargets()
+{
+    int registered = 0;
+    std::string errorMessage;
+    for (CMasternodeConfig::CMasternodeEntry mne : masternodeConfig.getEntries()) {
+        if (mne.getAlias().empty())
+            continue;
+        if (RegisterPingTarget(mne.getAlias(), errorMessage))
+            registered++;
+    }
+    return registered;
+}
+
+size_t CActiveMasternode::GetPingTargetCount() const
+{
+    LOCK(cs_pingTargets);
+    return mapExtraPingTargets.size();
+}
+
+void CActiveMasternode::ManageExtraPingTargets()
+{
+    if (!fMasterNode)
+        return;
+
+    LOCK(cs_pingTargets);
+    for (auto& it : mapExtraPingTargets) {
+        CMasternodePingTarget& target = it.second;
+
+        if (Params().NetworkID() != CBaseChainParams::REGTEST && !masternodeSync.IsBlockchainSynced()) {
+            target.status = ACTIVE_MASTERNODE_SYNC_IN_PROCESS;
+            continue;
+        }
+
+        if (target.status == ACTIVE_MASTERNODE_SYNC_IN_PROCESS)
+            target.status = ACTIVE_MASTERNODE_INITIAL;
+
+        if (target.status == ACTIVE_MASTERNODE_INITIAL || target.status == ACTIVE_MASTERNODE_NOT_CAPABLE) {
+            CMasternode* pmn = mnodeman.Find(target.vin);
+            if (pmn != NULL) {
+                pmn->Check();
+                target.vin = pmn->vin;
+                target.service = pmn->addr;
+                target.status = ACTIVE_MASTERNODE_STARTED;
+                target.notCapableReason = "";
+                LogPrintf("CActiveMasternode::ManageExtraPingTargets() - %s ready (%s)\n", target.alias, target.vin.ToString());
+            }
+            continue;
+        }
+
+        if (target.status == ACTIVE_MASTERNODE_STARTED) {
+            std::string err;
+            if (!SendMasternodePingForTarget(target, err)) {
+                if (fDebug)
+                    LogPrintf("CActiveMasternode::ManageExtraPingTargets() - %s ping: %s\n", target.alias, err);
+            }
+        }
+    }
+}
