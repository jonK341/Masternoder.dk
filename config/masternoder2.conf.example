# MasterNoder2 daemon RPC config for Masternoder.dk
# Copy to masternoder2.conf and set rpcpassword. Copy that file to the daemon data dir
# (e.g. ~/.masternoder2/masternoder2.conf on Linux). Set the same password in .env as MN2_RPC_PASSWORD.

server=1
rpcuser=mn2rpc
rpcpassword=Kp9mN2xL7vQw4jRc8sFb3hYt6nWz1aDg5
rpcport=9332
rpcallowip=127.0.0.1
rpcbind=127.0.0.1

# Multi-masternode hosting (platform fleet in masternode.conf):
#   Do NOT set masternode=1 unless you also set masternodeprivkey= and masternodeaddr=
#   for a single "local" node. masternode=1 without masternodeprivkey crashes the daemon.
#   Broadcast additional nodes with: startmasternode alias false <alias>
#
# Single local masternode only (optional — not used for multi-slot hosting):
# masternode=1
# masternodeprivkey=<createmasternodekey output>
# masternodeaddr=140.82.39.124:17646
