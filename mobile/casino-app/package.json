{
  "name": "masternoder-casino-app",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor shell for MasterNoder Casino (Android + iOS)",
  "scripts": {
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "build:android": "npm run cap:sync && cd android && (./gradlew assembleRelease || gradlew.bat assembleRelease)",
    "build:ios": "npm run cap:sync && npx cap open ios",
    "assets": "npx @capacitor/assets generate --iconBackgroundColor \"#1A1035\" --splashBackgroundColor \"#0A0E14\"",
    "postinstall": "node scripts/patch-capacitor-config.js"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
